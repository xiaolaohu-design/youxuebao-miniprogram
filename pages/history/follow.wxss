
.app-container.data-v-8abb3ef4 {
		width: 100%;
		height: 100vh;
		background-color: #f8fafc;
}
.scroll-container.data-v-8abb3ef4 {
		width: 100%;
		height: 100%;
}
.history-list.data-v-8abb3ef4 {
		padding: 20rpx 24rpx;
}

	/* Tab 导航 */
.tab-nav.data-v-8abb3ef4 {
		margin-bottom: 20rpx;
		background-color: #fff;
		border-radius: 16rpx;
		padding: 8rpx 0;
		box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.tabs-scroll.data-v-8abb3ef4 {
		width: 100%;
		white-space: nowrap;
}
.tabs-wrapper.data-v-8abb3ef4 {
		display: flex;
		align-items: center;
		gap: 4rpx;
}
.tab-item.data-v-8abb3ef4 {
		display: inline-flex;
		align-items: center;
		flex-direction: column;
		gap: 6rpx;
		padding: 20rpx 28rpx;
		position: relative;
		cursor: pointer;
}
.tab-text.data-v-8abb3ef4 {
		font-size: 28rpx;
		color: #64748b;
		font-weight: 450;
		transition: all 0.2s ease;
}
.tab-item--active .tab-text.data-v-8abb3ef4 {
		color: #2c62ef;
		font-weight: 600;
}
.tab-indicator.data-v-8abb3ef4 {
		position: absolute;
		bottom: 8rpx;
		left: 50%;
		transform: translateX(-50%);
		width: 36rpx;
		height: 5rpx;
		background: linear-gradient(135deg, #2c62ef, #1a4bd1);
		border-radius: 3rpx;
}

	/* 加载状态 */
.loading-state.data-v-8abb3ef4 {
		display: flex;
		justify-content: center;
		align-items: center;
		padding: 120rpx 0;
}
.loading-text.data-v-8abb3ef4 {
		font-size: 28rpx;
		color: #999;
}

	/* 空状态 */
.empty-state.data-v-8abb3ef4 {
