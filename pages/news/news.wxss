
.app-container.data-v-24bc9d41 {
		width: 100%;
		height: 100vh;
		background-color: #f8fafc;
}
.scroll-container.data-v-24bc9d41 {
		width: 100%;
		height: 100%;
}
.news-center.data-v-24bc9d41 {
		padding: 0 24rpx 20rpx;
		background-color: #f8fafc;
		min-height: 100vh;
		position: relative;
		z-index: 1;
}

	/* 分类标签 */
.category-tabs.data-v-24bc9d41 {
		margin: 20rpx 0;
		width: 100%;
		overflow: hidden;
}
.tabs-scroll.data-v-24bc9d41 {
		width: 100%;
		white-space: nowrap;
}
.tabs-wrapper.data-v-24bc9d41 {
		display: flex;
		align-items: center;
		gap: 4rpx;
		white-space: nowrap;
}
.tab-item.data-v-24bc9d41 {
		display: inline-flex;
		flex-direction: column;
		align-items: center;
		padding: 16rpx;
		position: relative;
		flex-shrink: 0;
		white-space: nowrap;
		max-width: 200rpx;
}
.tab-text.data-v-24bc9d41 {
		font-size: 30rpx;
		color: #64748b;
		font-weight: 450;
		transition: all 0.2s ease;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
}
.tab-item--active .tab-text.data-v-24bc9d41 {
		color: #3b82f6;
		font-weight: 600;
}
.tab-indicator.data-v-24bc9d41 {
		position: absolute;
		bottom: 4rpx;
		left: 50%;
		transform: translateX(-50%);
		width: 36rpx;
		height: 5rpx;
		background: #3b82f6;
		border-radius: 3rpx;
}

	/* 新闻列表 */
.news-list.data-v-24bc9d41 {
		padding-bottom: 40rpx;
}
.news-section.data-v-24bc9d41 {
		margin-bottom: 28rpx;
}

	/* 大图样式 */
.featured-news.data-v-24bc9d41 {
		background: #ffffff;
		border-radius: 20rpx;
		overflow: hidden;
		margin-bottom: 24rpx;
		box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
		cursor: pointer;
		transition: all 0.2s ease;
}
.featured-news.data-v-24bc9d41:active {
		transform: scale(0.99);
}
.featured-image.data-v-24bc9d41 {
		width: 100%;
		height: 360rpx;
		background-color: #e2e8f0;
}
.featured-content.data-v-24bc9d41 {
		padding: 20rpx 24rpx 24rpx;
}
.featured-title.data-v-24bc9d41 {
		font-size: 32rpx;
		font-weight: 650;
		color: #1e293b;
		line-height: 1.4;
		margin-bottom: 16rpx;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
}
.featured-meta.data-v-24bc9d41 {
		display: flex;
		align-items: center;
		justify-content: space-between;
}

	/* 普通文章列表 */
.news-item.data-v-24bc9d41 {
		display: flex;
		align-items: flex-start;
		padding: 24rpx 0;
		border-bottom: 1rpx solid #e2e8f0;
		cursor: pointer;
		transition: background-color 0.15s ease;
}
.news-item.data-v-24bc9d41:active {
		background-color: rgba(241, 245, 249, 0.5);
}
.news-item-content.data-v-24bc9d41 {
		flex: 1;
		padding-right: 20rpx;
}
.news-item-title.data-v-24bc9d41 {
		font-size: 30rpx;
		font-weight: 500;
		color: #1e293b;
		line-height: 1.45;
		margin-bottom: 12rpx;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
}
.news-item-meta.data-v-24bc9d41 {
		display: flex;
		align-items: center;
		gap: 16rpx;
}
.news-source.data-v-24bc9d41 {
		font-size: 24rpx;
		color: #94a3b8;
}
.news-time.data-v-24bc9d41 {
		font-size: 24rpx;
		color: #94a3b8;
}
.news-item-image.data-v-24bc9d41 {
		width: 180rpx;
		height: 120rpx;
		border-radius: 12rpx;
		flex-shrink: 0;
		background-color: #e2e8f0;
}

	/* 加载更多提示 */
.load-more.data-v-24bc9d41 {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 32rpx 0;
}
.load-more-text.data-v-24bc9d41 {
		font-size: 26rpx;
		color: #94a3b8;
}

	/* 空状态 */
.empty-state.data-v-24bc9d41 {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 120rpx 0;
}
.empty-image.data-v-24bc9d41 {
		width: 240rpx;
		height: 240rpx;
		margin-bottom: 24rpx;
}
.empty-text.data-v-24bc9d41 {
		font-size: 28rpx;
		color: #94a3b8;
}

	/* 弹窗 */
.modal-mask.data-v-24bc9d41 {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.5);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 1000;
		padding: 48rpx;
}
.modal-container.data-v-24bc9d41 {
		width: 100%;
		max-width: 640rpx;
		max-height: 80vh;
		background: #ffffff;
		border-radius: 40rpx;
		overflow: hidden;
		box-shadow: 0 32rpx 64rpx rgba(0, 0, 0, 0.12);
		animation: modalFadeIn-24bc9d41 0.25s ease;
		display: flex;
		flex-direction: column;
}
@keyframes modalFadeIn-24bc9d41 {
from {
			opacity: 0;
			transform: scale(0.9);
}
to {
			opacity: 1;
			transform: scale(1);
}
}
.modal-header.data-v-24bc9d41 {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 28rpx 32rpx 20rpx;
		border-bottom: 1rpx solid #e2e8f0;
		flex-shrink: 0;
}
.modal-title.data-v-24bc9d41 {
		font-size: 34rpx;
		font-weight: 650;
		color: #1e293b;
}
.modal-close.data-v-24bc9d41 {
		width: 56rpx;
		height: 56rpx;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 28rpx;
		background: #f1f5f9;
		cursor: pointer;
}
.modal-close.data-v-24bc9d41:active {
		background: #e2e8f0;
}
.modal-body.data-v-24bc9d41 {
		padding: 24rpx 32rpx;
		flex: 1;
		overflow-y: auto;
}
.modal-news-title.data-v-24bc9d41 {
		font-size: 36rpx;
		font-weight: 650;
		color: #1e293b;
		display: block;
		margin-bottom: 16rpx;
		line-height: 1.4;
}
.modal-news-meta.data-v-24bc9d41 {
		display: flex;
		align-items: center;
		gap: 24rpx;
		margin-bottom: 20rpx;
}
.meta-item.data-v-24bc9d41 {
		display: flex;
		align-items: center;
		gap: 8rpx;
}
.meta-text.data-v-24bc9d41 {
		font-size: 26rpx;
		color: #94a3b8;
}
.modal-news-image.data-v-24bc9d41 {
		width: 100%;
		height: 320rpx;
		border-radius: 16rpx;
		margin-bottom: 20rpx;
		background-color: #e2e8f0;
}

	/* 富文本内容 */
.modal-news-content.data-v-24bc9d41 {
		font-size: 30rpx;
		color: #475569;
		line-height: 1.8;
		word-break: break-word;
}
.modal-news-content.data-v-24bc9d41 p {
		margin-bottom: 20rpx;
		text-indent: 2em;
}
.modal-news-content.data-v-24bc9d41 img {
		max-width: 100%;
		height: auto;
		border-radius: 12rpx;
		margin: 16rpx 0;
}
.modal-footer.data-v-24bc9d41 {
		padding: 20rpx 32rpx 32rpx;
		border-top: 1rpx solid #e2e8f0;
		flex-shrink: 0;
}
.modal-action.data-v-24bc9d41 {
		display: flex;
		align-items: center;
		justify-content: center;
}
.action-btn.data-v-24bc9d41 {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8rpx;
		width: 200rpx;
		padding: 16rpx 0;
		border-radius: 40rpx;
		background: #eff6ff;
		cursor: pointer;
		transition: all 0.15s ease;
}
.action-btn.data-v-24bc9d41:active {
		background: #dbeafe;
		transform: scale(0.96);
}
.share-text.data-v-24bc9d41 {
		color: #3b82f6;
		font-weight: 500;
}
.news-center.data-v-24bc9d41::after {
		content: '';
		position: fixed;
		top: -20%;
		right: -20%;
		width: 400rpx;
		height: 400rpx;
		background: radial-gradient(circle, rgba(59, 130, 246, 0.03) 0%, transparent 70%);
		z-index: -1;
		border-radius: 50%;
		pointer-events: none;
}
.news-center.data-v-24bc9d41::before {
		content: '';
		position: fixed;
		bottom: 0;
		left: -10%;
		width: 350rpx;
		height: 350rpx;
		background: radial-gradient(circle, rgba(59, 130, 246, 0.04) 0%, transparent 70%);
		z-index: -1;
		border-radius: 50%;
		pointer-events: none;
}
