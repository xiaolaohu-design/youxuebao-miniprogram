		height: 30rpx;
}

	/*  协议勾选  */
.agreement-wrapper.data-v-838b72c9 {
		display: flex;
		flex-direction: row;
		align-items: center;
}
.checkbox-custom.data-v-838b72c9 {
		display: flex;
		align-items: center;
		margin-right: 10rpx;
}
.checkbox-box.data-v-838b72c9 {
		width: 30rpx;
		height: 30rpx;
		border: 2rpx solid #C9C9C9;
		border-radius: 50%;
		margin-top: 8rpx;
		margin-left: 10rpx;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.3s;
}
.checkbox-checked.data-v-838b72c9 {
		background-color: #2C62EF;
		border-color: #2C62EF;
}
.checkbox-icon.data-v-838b72c9 {
		color: #FFFFFF;
		font-size: 20rpx;
		font-weight: bold;
}
.agreement-text.data-v-838b72c9 {
		font-size: 26rpx;
		color: #646464;
		margin-left: 10rpx;
		line-height: 1.5;
}
.link-text.data-v-838b72c9 {
		color: #2C62EF;
		font-size: 26rpx;
}

