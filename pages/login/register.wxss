
	/*  外层容器样式  */
.app-container.data-v-838b72c9 {
		width: 100%;
		height: 100vh;
}
.scroll-container.data-v-838b72c9 {
		width: 100%;
		height: 100%;
}
.login-wrapper.data-v-838b72c9 {
		width: 100%;
		background-color: #FFFFFF;
		min-height: 100vh;
}
.register-container.data-v-838b72c9 {
		padding: 0 20rpx;
}

	/*  顶部导航区  */
.header-section.data-v-838b72c9 {
		position: relative;
		padding-top: 20rpx;
}
.nav-bar.data-v-838b72c9 {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		position: relative;
		z-index: 100;
}
.close-btn.data-v-838b72c9 {
		width: 80rpx;
		height: 80rpx;
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: bold;
		position: relative;
		z-index: 101;
		border-radius: 50%;
		transition: background-color 0.3s;
}
.close-btn.data-v-838b72c9:active {
		background-color: #F5F5F5;
}
.close-btn-hover.data-v-838b72c9 {
		background-color: #F5F5F5;
}
.close-icon.data-v-838b72c9 {
		font-size: 40rpx;
		color: #333333;
}
.nav-spacer.data-v-838b72c9 {
		flex: 1;
}
.login-btn-nav.data-v-838b72c9 {
		font-size: 30rpx;
		color: #646464;
		background-color: #FFFFFF;
		border: none;
		padding: 10rpx 20rpx;
		margin-right: 0;
		position: relative;
		z-index: 101;
}
.login-btn-nav.data-v-838b72c9::after {
		border: none;
}
.login-btn-nav.data-v-838b72c9:active {
		opacity: 0.7;
}

	/* 注册标题 */
.register-title.data-v-838b72c9 {
		margin-top: 20rpx;
}
.title-text.data-v-838b72c9 {
		font-weight: bold;
		font-size: 44rpx;
		color: #000000;
}

	/*  标题占位  */
.title-spacer.data-v-838b72c9 {
		padding-bottom: 70rpx;
}

	/*  表单区域  */
.form-wrapper.data-v-838b72c9 {
		padding: 0 20rpx;
}
.input-group.data-v-838b72c9 {
		margin-bottom: 20rpx;
		border-bottom: 1px solid #E5E5E5;
}
.code-group.data-v-838b72c9 {
		display: flex;
		align-items: stretch;
		margin-top: 60rpx;
}
.form-input.data-v-838b72c9 {
