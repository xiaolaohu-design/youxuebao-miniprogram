		border-top: 1px solid #E5E5E5;
		flex-shrink: 0;
}
.agreement-btn.data-v-838b72c9 {
		width: 100%;
		height: 80rpx;
		line-height: 80rpx;
		background-color: #2C62EF;
		color: #FFFFFF;
		font-size: 28rpx;
		border-radius: 40rpx;
