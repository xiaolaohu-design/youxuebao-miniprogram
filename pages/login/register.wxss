.agreement-modal.data-v-838b72c9 {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: rgba(0, 0, 0, 0.5);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 1000;
}
.agreement-content.data-v-838b72c9 {
		width: 85%;
		height: 70%;
		max-height: 80vh;
		background-color: #FFFFFF;
		border-radius: 20rpx;
		overflow: hidden;
		display: flex;
		flex-direction: column;
}
.agreement-header.data-v-838b72c9 {
		display: flex;
		align-items: center;
		justify-content: space-between;
