}

	/*  操作区域  */
.action-wrapper.data-v-838b72c9 {
		padding: 20rpx 20rpx;
}
.register-submit-btn.data-v-838b72c9 {
		width: 100%;
		height: 90rpx;
		line-height: 90rpx;
		background-color: #2C62EF;
		color: #FFFFFF;
		font-size: 30rpx;
		border-radius: 50rpx;
		border: 0;
		margin-top: 80rpx;
		position: relative;
}
.register-submit-btn.data-v-838b72c9::after {
		border: none;
}
.btn-disabled.data-v-838b72c9 {
