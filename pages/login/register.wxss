		border: none;
		padding: 0;
}
.wechat-btn.data-v-838b72c9::after {
		border: none;
}
.wechat-content.data-v-838b72c9 {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 8rpx;
}
.wechat-text.data-v-838b72c9 {
		font-size: 24rpx;
		color: #646464;
		text-align: center;
		line-height: 1;
