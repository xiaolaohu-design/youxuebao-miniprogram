		height: 30rpx;
}

	/*  底部链接  */
.bottom-links.data-v-79044ba6 {
		display: flex;
		justify-content: center;
		align-items: center;
		padding: 30rpx 0;
}
.link-text-item.data-v-79044ba6 {
		font-size: 28rpx;
		color: #2C62EF;
		padding: 10rpx 20rpx;
}
.link-separator.data-v-79044ba6 {
		font-size: 24rpx;
		color: #C9C9C9;
		margin: 0 10rpx;
}
