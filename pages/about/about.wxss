	/* ==================== 弹窗通用样式 ==================== */

	/* 蒙层 */
.modal-mask.data-v-13a78ac6 {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.5);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 1000;
		padding: 48rpx;
}

	/* 弹窗卡片 */
.modal-card.data-v-13a78ac6 {
		width: 100%;
		max-width: 600rpx;
		max-height: 75vh;
		background: #ffffff;
		border-radius: 40rpx;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		animation: modalFadeIn-13a78ac6 0.25s ease;
}
@keyframes modalFadeIn-13a78ac6 {
from {
			opacity: 0;
			transform: scale(0.9);
}
to {
			opacity: 1;
			transform: scale(1);
}
}

	/* 弹窗头部 */
.modal-header.data-v-13a78ac6 {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 28rpx 32rpx 20rpx;
		flex-shrink: 0;
		border-bottom: 1rpx solid #f1f5f9;
}
.modal-title.data-v-13a78ac6 {
		font-size: 34rpx;
		font-weight: 650;
		color: #1e293b;
}
.modal-close.data-v-13a78ac6 {
		width: 56rpx;
		height: 56rpx;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 28rpx;
		background: #f1f5f9;
}

	/* 弹窗可滚动内容区 */
.modal-scroll-body.data-v-13a78ac6 {
		flex: 1;
		min-height: 100rpx;
}
.modal-body-content.data-v-13a78ac6 {
