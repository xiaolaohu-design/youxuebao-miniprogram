
.app-container.data-v-acffb328 {
		width: 100%;
		height: 100vh;
		background-color: #f8fafc;
}
.scroll-container.data-v-acffb328 {
		width: 100%;
		height: 100%;
}
.exchange-list.data-v-acffb328 {
		padding: 0 24rpx 20rpx;
		background-color: #f8fafc;
		min-height: 100vh;
}

	/* 积分卡片 */
.points-card.data-v-acffb328 {
		background: linear-gradient(135deg, #e67e22 0%, #d35400 100%);
		border-radius: 28rpx;
		padding: 28rpx;
		margin: 20rpx 0 16rpx;
		display: flex;
		align-items: center;
		justify-content: space-between;
		box-shadow: 0 8rpx 24rpx rgba(230, 126, 34, 0.25);
}
.points-left.data-v-acffb328 {
		display: flex;
		flex-direction: column;
		gap: 8rpx;
}
.points-label.data-v-acffb328 {
		font-size: 26rpx;
		color: rgba(255, 255, 255, 0.85);
}
.points-value.data-v-acffb328 {
		font-size: 64rpx;
		font-weight: 700;
		color: #ffffff;
		line-height: 1;
}
.points-right.data-v-acffb328 {
		display: flex;
		align-items: center;
		gap: 4rpx;
		padding: 12rpx 20rpx;
		background: rgba(255, 255, 255, 0.2);
		border-radius: 40rpx;
		cursor: pointer;
}
.record-link.data-v-acffb328 {
		font-size: 24rpx;
		color: #ffffff;
}

	/* 状态标签 */
.status-tabs.data-v-acffb328 {
		margin-bottom: 20rpx;
}
.tabs-scroll.data-v-acffb328 {
		width: 100%;
		white-space: nowrap;
}
.tabs-wrapper.data-v-acffb328 {
		display: flex;
		align-items: center;
		gap: 4rpx;
}
.tab-item.data-v-acffb328 {
		display: inline-flex;
		align-items: center;
		padding: 16rpx 28rpx;
		position: relative;
		cursor: pointer;
}
.tab-text.data-v-acffb328 {
		font-size: 28rpx;
		color: #64748b;
		font-weight: 450;
		transition: all 0.2s ease;
}
.tab-item--active .tab-text.data-v-acffb328 {
		color: #e67e22;
		font-weight: 600;
}
.tab-indicator.data-v-acffb328 {
		position: absolute;
		bottom: 4rpx;
		left: 50%;
		transform: translateX(-50%);
		width: 36rpx;
		height: 5rpx;
		background: #e67e22;
		border-radius: 3rpx;
}

	/* 加载状态 */
.loading-state.data-v-acffb328 {
		display: flex;
		justify-content: center;
		align-items: center;
		padding: 120rpx 0;
}
.loading-text.data-v-acffb328 {
		font-size: 28rpx;
		color: #999;
}

	/* 空状态 */
.empty-state.data-v-acffb328 {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 100rpx 48rpx;
}
.empty-image.data-v-acffb328 {
		width: 240rpx;
		height: 240rpx;
		margin-bottom: 32rpx;
}
.empty-title.data-v-acffb328 {
		font-size: 32rpx;
		font-weight: 600;
		color: #1e293b;
		margin-bottom: 12rpx;
}
.empty-desc.data-v-acffb328 {
		font-size: 26rpx;
		color: #94a3b8;
		margin-bottom: 32rpx;
}
.empty-btn.data-v-acffb328 {
		padding: 20rpx 64rpx;
		background: linear-gradient(135deg, #e67e22 0%, #d35400 100%);
		border-radius: 48rpx;
		cursor: pointer;
}
.empty-btn text.data-v-acffb328 {
		font-size: 28rpx;
		color: #ffffff;
		font-weight: 500;
}

	/* 记录列表 */
.record-list.data-v-acffb328 {
		display: flex;
		flex-direction: column;
		gap: 16rpx;
		padding-bottom: 20rpx;
}
.record-item.data-v-acffb328 {
		background: #ffffff;
		border-radius: 20rpx;
		padding: 20rpx;
		display: flex;
		gap: 20rpx;
		box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
		cursor: pointer;
}
.record-image.data-v-acffb328 {
		width: 120rpx;
		height: 120rpx;
		border-radius: 16rpx;
		flex-shrink: 0;
}
.record-info.data-v-acffb328 {
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
}
.record-header.data-v-acffb328 {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 6rpx;
}
.record-name.data-v-acffb328 {
		font-size: 28rpx;
		font-weight: 500;
		color: #1e293b;
		flex: 1;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
}
.record-status.data-v-acffb328 {
		padding: 4rpx 12rpx;
		border-radius: 20rpx;
		font-size: 22rpx;
		flex-shrink: 0;
		margin-left: 12rpx;
}
.status-pending.data-v-acffb328 {
		background: #fef3e7;
		color: #e67e22;
}
.status-completed.data-v-acffb328 {
		background: #e8f5e9;
		color: #27ae60;
}
.status-cancelled.data-v-acffb328 {
		background: #f1f5f9;
		color: #94a3b8;
}
.record-time.data-v-acffb328 {
		font-size: 24rpx;
		color: #94a3b8;
		margin-bottom: 8rpx;
}
.record-footer.data-v-acffb328 {
		display: flex;
		align-items: center;
		justify-content: space-between;
}
.points-num.data-v-acffb328 {
		font-size: 26rpx;
		font-weight: 600;
		color: #e67e22;
}

	/* 加载更多 */
.loading-more.data-v-acffb328 {
		text-align: center;
		padding: 40rpx 0;
}
.loading-more text.data-v-acffb328 {
		font-size: 26rpx;
		color: #999;
}

	/* 没有更多 */
.no-more.data-v-acffb328 {
		text-align: center;
		padding: 40rpx 0;
}
.no-more text.data-v-acffb328 {
		font-size: 24rpx;
		color: #ccc;
}

	/* 弹窗样式 */
.modal-mask.data-v-acffb328 {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.5);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 1000;
		padding: 48rpx;
}
.detail-modal.data-v-acffb328 {
		width: 100%;
		max-width: 600rpx;
		max-height: 80vh;
		background: #ffffff;
		border-radius: 40rpx;
		overflow: hidden;
		animation: modalFadeIn-acffb328 0.25s ease;
		display: flex;
		flex-direction: column;
}
@keyframes modalFadeIn-acffb328 {
from {
			opacity: 0;
			transform: scale(0.9);
}
to {
			opacity: 1;
			transform: scale(1);
}
}
.detail-header.data-v-acffb328 {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 28rpx 32rpx 20rpx;
		border-bottom: 1rpx solid #e2e8f0;
		flex-shrink: 0;
}
.detail-title.data-v-acffb328 {
		font-size: 34rpx;
		font-weight: 650;
		color: #1e293b;
}
.detail-close.data-v-acffb328 {
		width: 56rpx;
		height: 56rpx;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 48rpx;
		color: #8599b0;
		border-radius: 28rpx;
		background: #f1f5f9;
}
.detail-body.data-v-acffb328 {
		padding: 24rpx 32rpx;
		flex: 1;
		overflow-y: auto;
}
.detail-name.data-v-acffb328 {
		font-size: 32rpx;
		font-weight: 600;
		color: #1e293b;
		display: block;
		margin-bottom: 24rpx;
}
.detail-info-grid.data-v-acffb328 {
		display: flex;
		flex-direction: column;
		gap: 20rpx;
		margin-bottom: 24rpx;
}
.info-row.data-v-acffb328 {
		display: flex;
		align-items: center;
		justify-content: space-between;
}
.info-label.data-v-acffb328 {
		font-size: 26rpx;
		color: #94a3b8;
}
.info-value.data-v-acffb328 {
		font-size: 26rpx;
		color: #1e293b;
}
.points-text.data-v-acffb328 {
		font-weight: 600;
		color: #e67e22;
}
.info-status.data-v-acffb328 {
		padding: 6rpx 16rpx;
		border-radius: 20rpx;
		font-size: 24rpx;
}
.detail-footer.data-v-acffb328 {
		padding: 20rpx 32rpx 32rpx;
		border-top: 1rpx solid #e2e8f0;
		flex-shrink: 0;
}
.detail-btn.data-v-acffb328 {
		width: 100%;
		height: 88rpx;
		background: linear-gradient(135deg, #e67e22 0%, #d35400 100%);
		border-radius: 48rpx;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
}
.detail-btn text.data-v-acffb328 {
		font-size: 30rpx;
		color: #ffffff;
		font-weight: 500;
}
.detail-btn.data-v-acffb328:active {
		transform: scale(0.98);
		opacity: 0.9;
}
