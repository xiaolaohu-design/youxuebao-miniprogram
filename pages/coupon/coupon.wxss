
.app-container.data-v-96ba783d {
		width: 100%;
		height: 100vh;
		background-color: #f8fafc;
}
.scroll-container.data-v-96ba783d {
		width: 100%;
		height: 100%;
}
.coupon-center.data-v-96ba783d {
		padding: 0 24rpx 20rpx;
		background-color: #f8fafc;
		min-height: 100vh;
}

	/* 分类标签 */
.category-tabs.data-v-96ba783d {
		padding-top: 16rpx;
		margin-bottom: 16rpx;
}
.tabs-scroll.data-v-96ba783d {
		width: 100%;
		white-space: nowrap;
}
.tabs-wrapper.data-v-96ba783d {
		display: flex;
		align-items: center;
		gap: 4rpx;
}
.tab-item.data-v-96ba783d {
		display: inline-flex;
		flex-direction: column;
		align-items: center;
		padding: 16rpx 32rpx;
		position: relative;
		cursor: pointer;
}
.tab-text.data-v-96ba783d {
		font-size: 30rpx;
		color: #64748b;
		font-weight: 450;
		transition: all 0.2s ease;
}
.tab-item--active .tab-text.data-v-96ba783d {
		color: #f59e0b;
		font-weight: 600;
}
.tab-indicator.data-v-96ba783d {
		position: absolute;
		bottom: 4rpx;
		left: 50%;
		transform: translateX(-50%);
		width: 36rpx;
		height: 5rpx;
		background: #f59e0b;
		border-radius: 3rpx;
}

	/* 标签筛选 */
.filter-tags.data-v-96ba783d {
		padding: 8rpx 0 16rpx;
		margin-bottom: 8rpx;
}
.tags-wrapper.data-v-96ba783d {
		display: flex;
		gap: 12rpx;
		white-space: nowrap;
		padding: 0 4rpx;
}
.tag-item.data-v-96ba783d {
		display: inline-flex;
		align-items: center;
		gap: 4rpx;
		padding: 10rpx 24rpx;
		background: #f1f5f9;
		border-radius: 32rpx;
		font-size: 24rpx;
		color: #64748b;
		transition: all 0.2s ease;
		flex-shrink: 0;
}
.tag-active.data-v-96ba783d {
		background: #fef3c7;
		color: #d97706;
		font-weight: 500;
}
.tag-count.data-v-96ba783d {
		font-size: 20rpx;
		opacity: 0.8;
}

	/* 优惠券列表 */
.coupon-list.data-v-96ba783d {
		padding-bottom: 40rpx;
}
.coupon-item.data-v-96ba783d {
		display: flex;
		background: #ffffff;
		border-radius: 20rpx;
		margin-bottom: 24rpx;
		overflow: hidden;
		box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
		position: relative;
}
.coupon-item--expired.data-v-96ba783d {
		opacity: 0.7;
}
.coupon-item--soldout.data-v-96ba783d {
		border-left: 4rpx solid #ef4444;
}

	/* 左侧面值 */
.coupon-left.data-v-96ba783d {
		width: 200rpx;
		padding: 28rpx 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
}
.coupon-value.data-v-96ba783d {
		display: flex;
		align-items: baseline;
}
.currency.data-v-96ba783d {
		font-size: 28rpx;
		color: #d97706;
		font-weight: 600;
		margin-right: 4rpx;
}
.amount.data-v-96ba783d {
		font-size: 64rpx;
		font-weight: 700;
		color: #d97706;
		line-height: 1;
}
.coupon-condition.data-v-96ba783d {
		font-size: 24rpx;
		color: #b45309;
		margin-top: 8rpx;
}

	/* 分割线 */
.coupon-divider.data-v-96ba783d {
		width: 2rpx;
		position: relative;
		background: repeating-linear-gradient(to bottom,
				#e2e8f0 0rpx,
				#e2e8f0 6rpx,
				transparent 6rpx,
				transparent 12rpx);
}
.circle.data-v-96ba783d {
		position: absolute;
		width: 16rpx;
		height: 16rpx;
		background: #f8fafc;
		border-radius: 50%;
		left: -8rpx;
}
.circle.top.data-v-96ba783d {
		top: -8rpx;
}
.circle.bottom.data-v-96ba783d {
		bottom: -8rpx;
}

	/* 右侧信息 */
.coupon-right.data-v-96ba783d {
		flex: 1;
		padding: 24rpx 20rpx 24rpx 24rpx;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
}
.coupon-info.data-v-96ba783d {
		display: flex;
		flex-direction: column;
		gap: 8rpx;
}
.coupon-name.data-v-96ba783d {
		font-size: 30rpx;
		font-weight: 600;
		color: #1e293b;
}
.coupon-desc.data-v-96ba783d {
		font-size: 24rpx;
		color: #94a3b8;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
}
.coupon-scope.data-v-96ba783d {
		font-size: 24rpx;
		color: #94a3b8;
}
.coupon-time.data-v-96ba783d {
		font-size: 22rpx;
		color: #cbd5e1;
}
.coupon-action.data-v-96ba783d {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: 12rpx;
}
.action-btn.data-v-96ba783d {
		padding: 12rpx 28rpx;
		border-radius: 40rpx;
		cursor: pointer;
		transition: all 0.15s ease;
}
.btn-primary.data-v-96ba783d {
		background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
		color: #ffffff;
		font-size: 26rpx;
		font-weight: 500;
		box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.3);
}
.btn-primary.data-v-96ba783d:active {
		transform: scale(0.96);
		box-shadow: 0 2rpx 8rpx rgba(245, 158, 11, 0.25);
}
.btn-outline.data-v-96ba783d {
		background: #ffffff;
		border: 1rpx solid #f59e0b;
		color: #f59e0b;
		font-size: 26rpx;
		font-weight: 500;
}
.btn-outline.data-v-96ba783d:active {
		background: #fef3c7;
}
.btn-claimed.data-v-96ba783d {
		background: #d1fae5;
		color: #059669;
		font-size: 26rpx;
		font-weight: 500;
}
.btn-disabled.data-v-96ba783d {
		background: #e2e8f0;
		color: #94a3b8;
		font-size: 26rpx;
		font-weight: 500;
}
.coupon-stock.data-v-96ba783d {
		font-size: 22rpx;
		color: #cbd5e1;
}

	/* 遮罩 */
.coupon-mask.data-v-96ba783d {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		backdrop-filter: blur(2px);
		-webkit-backdrop-filter: blur(2px);
}
.mask-text.data-v-96ba783d {
		font-size: 36rpx;
		font-weight: 600;
		color: #94a3b8;
		transform: rotate(-15deg);
		border: 3rpx solid #94a3b8;
		padding: 8rpx 24rpx;
		border-radius: 8rpx;
		background: rgba(255, 255, 255, 0.8);
		position: absolute;
		right: 5%;
		top: 50%;
		transform: translate(0, -50%) rotate(-15deg);
}

	/* 空状态 */
.empty-state.data-v-96ba783d {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 120rpx 0;
}
.empty-image.data-v-96ba783d {
		width: 240rpx;
		height: 240rpx;
		margin-bottom: 24rpx;
}
.empty-text.data-v-96ba783d {
		font-size: 32rpx;
		color: #64748b;
		font-weight: 500;
}
.empty-tip.data-v-96ba783d {
		font-size: 24rpx;
		color: #cbd5e1;
		margin-top: 8rpx;
}


	/* 领取成功弹窗 */
.modal-mask.data-v-96ba783d {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(0, 0, 0, 0.5);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 1000;
		padding: 48rpx;
}
.success-modal.data-v-96ba783d {
		width: 100%;
		max-width: 500rpx;
		background: #ffffff;
		border-radius: 40rpx;
		padding: 48rpx 32rpx 40rpx;
		display: flex;
		flex-direction: column;
		align-items: center;
		animation: modalFadeIn-96ba783d 0.25s ease;
}
@keyframes modalFadeIn-96ba783d {
from {
			opacity: 0;
			transform: scale(0.9);
}
to {
			opacity: 1;
			transform: scale(1);
}
}
.success-icon.data-v-96ba783d {
		width: 100rpx;
		height: 100rpx;
		background: linear-gradient(135deg, #10b981 0%, #059669 100%);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 24rpx;
		box-shadow: 0 8rpx 20rpx rgba(16, 185, 129, 0.3);
}
.success-title.data-v-96ba783d {
		font-size: 36rpx;
		font-weight: 650;
		color: #1e293b;
		margin-bottom: 12rpx;
}
.success-desc.data-v-96ba783d {
		font-size: 28rpx;
		color: #64748b;
		margin-bottom: 32rpx;
}
.success-btn.data-v-96ba783d {
		width: 100%;
		height: 88rpx;
		background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
		border-radius: 48rpx;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #ffffff;
		font-size: 30rpx;
		font-weight: 500;
		cursor: pointer;
}
.success-btn.data-v-96ba783d:active {
		transform: scale(0.98);
		opacity: 0.9;
}
