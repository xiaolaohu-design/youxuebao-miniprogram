		padding: 24rpx 32rpx 48rpx;
}
.reset-btn.data-v-30eef855,
	.confirm-btn.data-v-30eef855 {
		flex: 1;
		height: 88rpx;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 48rpx;
		font-size: 32rpx;
		font-weight: 500;
}
.reset-btn.data-v-30eef855 {
		background: #f6f6f6;
		color: #666666;
}
.reset-btn.data-v-30eef855:active {
		background: #e8e8e8;
}
.confirm-btn.data-v-30eef855 {
